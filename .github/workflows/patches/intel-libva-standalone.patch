+static char *va_getLibraryDirectory(void)
+{
+#if !defined(_WIN32)
+    Dl_info dl_info;
+
+    if (dladdr((void *)va_getLibraryDirectory, &dl_info) == 0 || dl_info.dli_fname == NULL)
+        return NULL;
+
+    char *library_path = realpath(dl_info.dli_fname, NULL);
+    if (!library_path)
+        library_path = strdup(dl_info.dli_fname);
+    if (!library_path)
+        return NULL;
+
+    char *last_slash = strrchr(library_path, '/');
+    if (!last_slash) {
+        free(library_path);
+        return NULL;
+    }
+
+    *last_slash = '\0';
+    return library_path;
+#else
+    return NULL;
+#endif
+}
+
+static char *va_resolvePathFromLibraryDirectory(const char *path)
+{
+    if (!path)
+        return NULL;
+
+#if !defined(_WIN32)
+    if (path[0] == '/')
+        return strdup(path);
+
+    char *library_dir = va_getLibraryDirectory();
+    if (!library_dir)
+        return strdup(path);
+
+    int path_length = snprintf(NULL, 0, "%s/%s", library_dir, path);
+    if (path_length < 0) {
+        free(library_dir);
+        return NULL;
+    }
+
+    char *resolved_path = malloc(path_length + 1);
+    if (!resolved_path) {
+        free(library_dir);
+        return NULL;
+    }
+
+    snprintf(resolved_path, path_length + 1, "%s/%s", library_dir, path);
+    free(library_dir);
+    return resolved_path;
+#else
+    return strdup(path);
+#endif
+}
