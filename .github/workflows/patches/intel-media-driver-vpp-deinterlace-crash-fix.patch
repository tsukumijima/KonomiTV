+        allocParamsForInputCopySurface.TileType = MOS_TILE_Y;
+        allocParamsForInputCopySurface.dwWidth  = MOS_ALIGN_CEIL(m_frameWidth, CODECHAL_MACROBLOCK_WIDTH);
+        allocParamsForInputCopySurface.dwHeight = MOS_ALIGN_CEIL(m_frameHeight, CODECHAL_MACROBLOCK_HEIGHT);
+        allocParamsForInputCopySurface.pBufName = "HEVC Input Copy Surface";
