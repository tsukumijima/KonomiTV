+MOS_STATUS CopySemiPlanarSurfaceForEncode(EncodeAllocator *allocator, MOS_SURFACE &sourceSurface, MOS_SURFACE &targetSurface)
+{
+    ENCODE_CHK_NULL_RETURN(allocator);
+
+    if (sourceSurface.Format != targetSurface.Format)
+    {
+        return MOS_STATUS_INVALID_PARAMETER;
+    }
+
+    if (sourceSurface.Format != Format_NV12 &&
+        sourceSurface.Format != Format_P010 &&
+        sourceSurface.Format != Format_P016)
+    {
+        return MOS_STATUS_INVALID_PARAMETER;
+    }
+
+    auto sourceData = static_cast<uint8_t *>(allocator->LockResourceForRead(&sourceSurface.OsResource));
+    ENCODE_CHK_NULL_RETURN(sourceData);
+
+    auto targetData = static_cast<uint8_t *>(allocator->LockResourceForWrite(&targetSurface.OsResource));
+    if (targetData == nullptr)
+    {
+        allocator->UnLock(&sourceSurface.OsResource);
+        return MOS_STATUS_INVALID_PARAMETER;
+    }
+
+    MOS_STATUS copyStatus = MOS_STATUS_SUCCESS;
+    uint32_t   copyPitch = MOS_MIN(sourceSurface.dwPitch, targetSurface.dwPitch);
+    uint32_t   lumaHeight = MOS_MIN(sourceSurface.dwHeight, targetSurface.dwHeight);
+    uint32_t   chromaHeight = lumaHeight / 2;
+
+    for (uint32_t row = 0; row < lumaHeight; ++row)
+    {
+        copyStatus = MOS_SecureMemcpy(
+            targetData + row * targetSurface.dwPitch,
+            copyPitch,
+            sourceData + row * sourceSurface.dwPitch,
+            copyPitch);
+        if (copyStatus != MOS_STATUS_SUCCESS)
+        {
+            break;
+        }
+    }
+
+    if (copyStatus == MOS_STATUS_SUCCESS)
+    {
+        auto sourceChroma = sourceData + sourceSurface.dwPitch * sourceSurface.dwHeight;
+        auto targetChroma = targetData + targetSurface.dwPitch * targetSurface.dwHeight;
+
+        for (uint32_t row = 0; row < chromaHeight; ++row)
+        {
+            copyStatus = MOS_SecureMemcpy(
+                targetChroma + row * targetSurface.dwPitch,
+                copyPitch,
+                sourceChroma + row * sourceSurface.dwPitch,
+                copyPitch);
+            if (copyStatus != MOS_STATUS_SUCCESS)
+            {
+                break;
+            }
+        }
+    }
+
+    allocator->UnLock(&targetSurface.OsResource);
+    allocator->UnLock(&sourceSurface.OsResource);
+
+    return copyStatus;
+}
+}
+
+bool HevcBasicFeature::ShouldDecoupleInputSurface() const
+{
+    // HEVC encode can keep the incoming raw surface alive longer than VP expects,
+    // especially when the surface originates from VEBOX DI output. Route the raw
+    // input through an encode-owned tracked surface so VP can recycle its own
+    // temporary outputs without sharing ownership with the encoder.
+    return true;
+}
