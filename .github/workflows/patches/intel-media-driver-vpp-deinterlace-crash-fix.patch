+MOS_STATUS VpVeboxCmdPacket::SubmitStagingCopies()
+{
+    VP_FUNC_CALL();
+
+    // Calling the staging copy from Submit() queues GPU copy work before the
+    // VEBOX command buffer is submitted to the kernel because Submit() only
+    // records the command buffer. Running these copies after the task submit
+    // keeps the existing staging behavior while making the copies queue after
+    // the VEBOX work that produces pCurrOutput.
+
+    const bool currentOutputProduced =
+        m_DIOutputFrames == MEDIA_VEBOX_DI_OUTPUT_CURRENT ||
+        m_DIOutputFrames == MEDIA_VEBOX_DI_OUTPUT_BOTH;
+
+    // 60fps DI reuses FRAME1 as the input of the following same-sample packet.
+    // After FRAME1 is replaced with a dedicated staging surface, every packet
+    // that produces a current output has to refresh that staging surface. This
+    // includes first/no-reference packets where VEBOX emits CURRENT only;
+    // restricting the copy to BOTH leaves stale pixels in the same-sample input
+    // and causes alternating or old-field flicker after reference resets.
+    if (m_mediaCopyWrapper != nullptr &&
+        m_PacketCaps.bDI &&
+        m_PacketCaps.bSFC &&
+        currentOutputProduced &&
+        m_veboxPacketSurface.pCurrOutput != nullptr &&
+        m_veboxPacketSurface.pSameSampleInput != nullptr &&
+        m_veboxPacketSurface.pCurrOutput->osSurface != nullptr &&
+        m_veboxPacketSurface.pSameSampleInput->osSurface != nullptr)
+    {
+        VP_RENDER_CHK_STATUS_RETURN(m_mediaCopyWrapper->MediaCopy(
+            &m_veboxPacketSurface.pCurrOutput->osSurface->OsResource,
+            &m_veboxPacketSurface.pSameSampleInput->osSurface->OsResource,
+            MCPY_METHOD_BALANCE));
+    }
+
+    return MOS_STATUS_SUCCESS;
+}
