+}
+
+inline void ClearVppDiScheduler(mfxSession session)
+{
+    if (session == nullptr)
+    {
+        return;
+    }
+
+    auto &state = GetVppDiMemIdRegistryState();
+    std::lock_guard<std::mutex> lock(state.mutex);
+
+    auto existing_scheduler = state.session_to_scheduler.find(session);
+    if (existing_scheduler == std::end(state.session_to_scheduler))
+    {
+        return;
+    }
+
+    auto refcount = state.scheduler_refcounts.find(existing_scheduler->second);
+    if (refcount != std::end(state.scheduler_refcounts))
+    {
+        if (refcount->second > 1)
+        {
+            refcount->second -= 1;
+        }
+        else
+        {
+            state.scheduler_refcounts.erase(refcount);
+        }
+    }
+
+    auto existing_high_frame_rate = state.session_is_high_frame_rate_di.find(session);
+    if (existing_high_frame_rate != std::end(state.session_is_high_frame_rate_di)
+        && existing_high_frame_rate->second)
+    {
+        auto high_frame_rate_refcount = state.scheduler_high_frame_rate_refcounts.find(existing_scheduler->second);
+        if (high_frame_rate_refcount != std::end(state.scheduler_high_frame_rate_refcounts))
+        {
+            if (high_frame_rate_refcount->second > 1)
+            {
+                high_frame_rate_refcount->second -= 1;
+            }
+            else
+            {
+                state.scheduler_high_frame_rate_refcounts.erase(high_frame_rate_refcount);
+            }
+        }
+    }
+
+    state.session_is_high_frame_rate_di.erase(session);
+    state.session_to_scheduler.erase(existing_scheduler);
+}
+
+inline void ClearVppDiOutputMemIds(mfxSession session)
+{
+    if (session == nullptr)
+    {
+        return;
+    }
+
+    auto& state = GetVppDiMemIdRegistryState();
+    std::lock_guard<std::mutex> lock(state.mutex);
+
+    auto session_memids = state.session_to_memids.find(session);
+    if (session_memids == std::end(state.session_to_memids))
+    {
+        return;
+    }
+
+    for (auto mid : session_memids->second)
+    {
+        auto refcount = state.memid_refcounts.find(mid);
+        if (refcount == std::end(state.memid_refcounts))
+        {
+            continue;
+        }
+
+        if (refcount->second > 1)
+        {
+            refcount->second -= 1;
+        }
+        else
+        {
+            state.memid_refcounts.erase(refcount);
+        }
+    }
+
+    state.session_to_memids.erase(session_memids);
+}
