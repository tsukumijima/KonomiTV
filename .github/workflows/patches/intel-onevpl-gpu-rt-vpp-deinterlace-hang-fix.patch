+struct VppDiMemIdRegistryState
+{
+    std::mutex                                             mutex;
+    std::unordered_map<mfxSession, std::unordered_set<mfxMemId>> session_to_memids;
+    std::unordered_map<mfxMemId, uint32_t>                 memid_refcounts;
+    std::unordered_map<mfxSession, bool>                   session_is_high_frame_rate_di;
+    std::unordered_map<mfxSession, MFXIScheduler *>        session_to_scheduler;
+    std::unordered_map<MFXIScheduler *, uint32_t>          scheduler_refcounts;
+    std::unordered_map<MFXIScheduler *, uint32_t>          scheduler_high_frame_rate_refcounts;
+};
+
+inline VppDiMemIdRegistryState& GetVppDiMemIdRegistryState()
+{
+    static VppDiMemIdRegistryState state;
+    return state;
+}
+
+inline void SetVppDiOutputMemId(mfxSession session, mfxMemId mid, bool is_vpp_di_output)
+{
+    if (session == nullptr || mid == nullptr)
+    {
+        return;
+    }
+
+    auto& state = GetVppDiMemIdRegistryState();
+    std::lock_guard<std::mutex> lock(state.mutex);
+    auto& session_memids = state.session_to_memids[session];
+
+    if (is_vpp_di_output)
+    {
+        const auto insert_result = session_memids.insert(mid);
+        if (insert_result.second)
+        {
+            state.memid_refcounts[mid] += 1;
+        }
+    }
+    else
+    {
+        const size_t erased_count = session_memids.erase(mid);
+        if (erased_count == 0)
+        {
+            return;
+        }
+
+        auto refcount = state.memid_refcounts.find(mid);
+        if (refcount == std::end(state.memid_refcounts))
+        {
+            return;
+        }
+
+        if (refcount->second > 1)
+        {
+            refcount->second -= 1;
+        }
+        else
+        {
+            state.memid_refcounts.erase(refcount);
+        }
+
+        if (session_memids.empty())
+        {
+            state.session_to_memids.erase(session);
+        }
+    }
+}
+
+inline bool IsVppDiOutputMemId(mfxMemId mid)
+{
+    if (mid == nullptr)
+    {
+        return false;
+    }
+
+    auto& state = GetVppDiMemIdRegistryState();
+    std::lock_guard<std::mutex> lock(state.mutex);
+    return state.memid_refcounts.find(mid) != std::end(state.memid_refcounts);
+}
+
+inline void SetVppDiScheduler(
